  {
    "type": "function",
    "function": {
      "name": "search_availability",
      "description": "Search available OPD appointment slots by department, doctor, date, and time window.",
      "parameters": {
        "type": "object",
        "properties": {
          "department": {
            "type": "string",
            "description": "Department name or symptom, for example heart, skin, eye, Cardiology, Dermatology."
          },
          "doctor_name": {
            "type": "string",
            "description": "Doctor name if the patient asks for a specific doctor."
          },
          "preferred_date": {
            "type": "string",
            "description": "Preferred date in YYYY-MM-DD format, or today, tomorrow, +2."
          },
          "time_window": {
            "type": "string",
            "enum": ["morning", "afternoon", "evening"],
            "description": "Preferred time window."
          },
          "appointment_type": {
            "type": "string",
            "description": "Usually General OPD."
          },
          "limit": {
            "type": "integer",
            "description": "Number of slots to return."
          }
        }
      }
    },
    "server": {
      "url": "https://YOUR_BACKEND_URL/vapi/webhook",
      "headers": {
        "x-vapi-secret": "change-this-secret"
      }
    }
  },
